    "requirement_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "applicability",
        "result",
        "evidence_ids",
        "verification_step"
      ],
      "properties": {
        "requirement_id": {
          "type": "string",
          "pattern": "^REQ-0(0[1-9]|[1-2][0-9]|3[0-8])$"
        },
        "applicability": {
          "type": "string",
          "enum": [
            "APPLICABLE",
            "NOT_APPLICABLE"
          ]
        },
        "result": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL",
            "NOT_ASSESSED"
          ]
        },
        "evidence_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "verification_step": {
          "type": "integer",
          "minimum": 1,
          "maximum": 27
        },
        "failure_code": {
          "type": "string",
          "enum": [
            "RMFPAY-ID-001",
            "RMFPAY-ID-002",
            "RMFPAY-ID-003",
            "RMFPAY-INS-001",
            "RMFPAY-AMT-001",
            "RMFPAY-AMT-002",
            "RMFPAY-AUT-001",
            "RMFPAY-AUT-002",
            "RMFPAY-AUT-003",
            "RMFPAY-DUP-001",
            "RMFPAY-DUP-002",
            "RMFPAY-EXE-001",
            "RMFPAY-STA-001",
            "RMFPAY-STA-002",
            "RMFPAY-SET-001",
            "RMFPAY-SET-002",
            "RMFPAY-FIN-001",
            "RMFPAY-FIN-002",
            "RMFPAY-FIN-003",
            "RMFPAY-FIN-004",
            "RMFPAY-FX-001",
            "RMFPAY-FEE-001",
            "RMFPAY-ERR-001",
            "RMFPAY-REV-001",
            "RMFPAY-REV-002",
            "RMFPAY-DSP-001",
            "RMFPAY-RET-001",
            "RMFPAY-DAT-001",
            "RMFPAY-EVD-001",
            "RMFPAY-EVD-002",
            "RMFPAY-EVD-003",
            "RMFPAY-SIG-001",
            "RMFPAY-VER-001",
            "RMFPAY-EVT-001",
            "RMFPAY-TIM-001",
            "RMFPAY-AGT-001",
            "RMFPAY-AGT-002"
          ]
        }
      },
      "allOf": [
        {
          "description": "Section 15.3: a FAIL result requires a failure code.",
          "if": {
            "properties": {
              "result": {
                "const": "FAIL"
              }
            },
            "required": [
              "result"
            ]
          },
          "then": {
            "required": [
              "failure_code"
            ]
          }
        }
      ]
    },
