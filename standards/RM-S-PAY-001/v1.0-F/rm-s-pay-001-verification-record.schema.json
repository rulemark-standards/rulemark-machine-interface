{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rulemark.org/schema/rm-s-pay-001/v1.0-F/verification-record.schema.json",
  "title": "RM-S-PAY-001 Digital Payment Verification Record",
  "description": "Machine-readable verification record for the RuleMark RM-S-PAY-001 Digital Payment Verification Standard. Derived strictly from Section 18 (Machine Interface), with enumerations from Sections 16, 17 and 18.4, evidence structure from Section 14, and object field definitions from Sections 5 to 13. This schema adds no obligations beyond those defined in the standard.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_id",
    "schema_version",
    "verification_time",
    "standard",
    "conformity_subject",
    "obligated_party",
    "parties",
    "payment_instruction",
    "authorization",
    "execution",
    "status_history",
    "fees",
    "adjustments",
    "disputes",
    "material_events",
    "evidence",
    "requirement_results",
    "human_disclosure",
    "overall_result",
    "verifier",
    "signature",
    "time_sources"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "schema_version": {
      "const": "1.0"
    },
    "verification_time": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "result_expires_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$",
      "description": "Required where the payment is not in a terminal state (Section 16.5); MUST be no later than 24 hours after verification_time."
    },
    "digest_algorithm": {
      "type": "string",
      "default": "sha-256",
      "description": "Digest algorithm identifier (Section 18.7)."
    },
    "standard": {
      "$ref": "#/$defs/standard"
    },
    "conformity_subject": {
      "$ref": "#/$defs/conformity_subject"
    },
    "obligated_party": {
      "$ref": "#/$defs/obligated_party"
    },
    "parties": {
      "$ref": "#/$defs/parties"
    },
    "payment_instruction": {
      "$ref": "#/$defs/payment_instruction"
    },
    "authorization": {
      "$ref": "#/$defs/authorization"
    },
    "execution": {
      "$ref": "#/$defs/execution"
    },
    "status_history": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/status_event"
      }
    },
    "settlement": {
      "$ref": "#/$defs/settlement"
    },
    "finality": {
      "$ref": "#/$defs/finality"
    },
    "fees": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/fee"
      }
    },
    "exchange_rate": {
      "$ref": "#/$defs/exchange_rate"
    },
    "adjustments": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/adjustment"
      }
    },
    "disputes": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/dispute"
      }
    },
    "material_events": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/material_event"
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "requirement_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/requirement_result"
      }
    },
    "human_disclosure": {
      "$ref": "#/$defs/human_disclosure"
    },
    "overall_result": {
      "$ref": "#/$defs/overall_result"
    },
    "verifier": {
      "$ref": "#/$defs/verifier"
    },
    "signature": {
      "$ref": "#/$defs/signature"
    },
    "time_sources": {
      "$ref": "#/$defs/time_sources"
    }
  },
  "allOf": [
    {
      "description": "Section 18.1: settlement is required where the current status is SETTLED.",
      "if": {
        "properties": {
          "status_history": {
            "contains": {
              "properties": {
                "status": {
                  "const": "SETTLED"
                }
              },
              "required": [
                "status"
              ]
            }
          }
        },
        "required": [
          "status_history"
        ]
      },
      "then": {
        "required": [
          "settlement"
        ]
      }
    },
    {
      "description": "Section 18.1: agent is required for AGENT_PAYMENT subjects.",
      "if": {
        "properties": {
          "conformity_subject": {
            "properties": {
              "conformity_subject_type": {
                "const": "AGENT_PAYMENT"
              }
            },
            "required": [
              "conformity_subject_type"
            ]
          }
        },
        "required": [
          "conformity_subject"
        ]
      },
      "then": {
        "properties": {
          "parties": {
            "required": [
              "payer",
              "payee",
              "agent"
            ]
          }
        }
      }
    },
    {
      "description": "Section 5.1: exactly one of payment_id or batch_id.",
      "properties": {
        "conformity_subject": {
          "oneOf": [
            {
              "required": [
                "payment_id"
              ],
              "not": {
                "required": [
                  "batch_id"
                ]
              }
            },
            {
              "required": [
                "batch_id"
              ],
              "not": {
                "required": [
                  "payment_id"
                ]
              }
            }
          ]
        }
      }
    },
    {
      "description": "Section 18.8: where settlement is present, its time source MUST be declared.",
      "if": {
        "required": [
          "settlement"
        ]
      },
      "then": {
        "properties": {
          "time_sources": {
            "required": [
              "verification_time_source",
              "settlement_time_source"
            ]
          }
        }
      }
    },
    {
      "description": "Section 18.8: where finality is present, its time source MUST be declared.",
      "if": {
        "required": [
          "finality"
        ]
      },
      "then": {
        "properties": {
          "time_sources": {
            "required": [
              "verification_time_source",
              "finality_time_source"
            ]
          }
        }
      }
    },
    {
      "description": "Section 10.6: IRREVOCABLE requires the three stated conditions to be recorded.",
      "if": {
        "properties": {
          "finality": {
            "properties": {
              "finality_state": {
                "const": "IRREVOCABLE"
              }
            },
            "required": [
              "finality_state"
            ]
          }
        },
        "required": [
          "finality"
        ]
      },
      "then": {
        "properties": {
          "finality": {
            "required": [
              "operational_finality_reached",
              "reversal_windows_expired",
              "window_expiry_evidence_id",
              "obligated_party_can_reverse"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "standard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standard_id",
        "standard_version",
        "machine_identifier",
        "authoritative_language"
      ],
      "properties": {
        "standard_id": {
          "const": "RM-S-PAY-001"
        },
        "standard_version": {
          "type": "string",
          "minLength": 1
        },
        "machine_identifier": {
          "const": "rulemark:standard:rm-s-pay-001:v1.0-F"
        },
        "authoritative_language": {
          "type": "string",
          "enum": [
            "ENGLISH"
          ]
        }
      }
    },
    "conformity_subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conformity_subject_type",
        "conformity_subject_id",
        "payment_network",
        "environment",
        "implementation_name",
        "implementation_version"
      ],
      "properties": {
        "conformity_subject_type": {
          "type": "string",
          "enum": [
            "SINGLE_PAYMENT",
            "PAYMENT_BATCH",
            "PAYMENT_PROCESS",
            "AGENT_PAYMENT",
            "IMPLEMENTATION"
          ]
        },
        "conformity_subject_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "payment_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "batch_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "payment_network": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "environment": {
          "type": "string",
          "enum": [
            "PRODUCTION",
            "SANDBOX"
          ]
        },
        "implementation_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "implementation_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        }
      }
    },
    "obligated_party": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "obligated_party_id",
        "legal_name",
        "jurisdiction",
        "responsibility_statement_uri",
        "identity_evidence_id"
      ],
      "properties": {
        "obligated_party_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "legal_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "jurisdiction": {
          "type": "string",
          "minLength": 2,
          "maxLength": 16
        },
        "responsibility_statement_uri": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        },
        "identity_evidence_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "parties": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "payer",
        "payee"
      ],
      "properties": {
        "payer": {
          "$ref": "#/$defs/party"
        },
        "payee": {
          "$ref": "#/$defs/party"
        },
        "agent": {
          "$ref": "#/$defs/agent"
        }
      }
    },
    "party": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "party_id",
        "identifier_type",
        "identity_evidence_id"
      ],
      "properties": {
        "party_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "identifier_type": {
          "type": "string",
          "enum": [
            "LEGAL_ID",
            "ACCOUNT_ID",
            "WALLET_ADDRESS",
            "PROTECTED_ALIAS",
            "DID"
          ]
        },
        "identity_evidence_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_id",
        "principal_id",
        "authorization_scope",
        "max_single_payment_amount",
        "allowed_payee_ids",
        "authorization_expires_at"
      ],
      "properties": {
        "agent_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "principal_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "authorization_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "max_single_payment_amount": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?$"
        },
        "allowed_payee_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "authorization_expires_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        }
      }
    },
    "payment_instruction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "payment_id",
        "idempotency_key",
        "created_at",
        "purpose_code",
        "gross_amount",
        "currency",
        "decimals",
        "instruction_digest"
      ],
      "properties": {
        "payment_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "idempotency_key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "created_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        },
        "purpose_code": {
          "type": "string",
          "enum": [
            "GOODS",
            "SERVICES",
            "TRANSFER",
            "SUBSCRIPTION",
            "TAX",
            "DONATION",
            "OTHER"
          ]
        },
        "purpose_description": {
          "type": "string",
          "maxLength": 500
        },
        "gross_amount": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?$"
        },
        "currency": {
          "type": "string",
          "minLength": 1
        },
        "decimals": {
          "type": "integer",
          "minimum": 0,
          "maximum": 30
        },
        "instruction_digest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authorization_id",
        "authorizer_id",
        "authorization_method",
        "authorized_at",
        "authorization_scope",
        "instruction_digest",
        "evidence_id"
      ],
      "properties": {
        "authorization_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "authorizer_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "authorization_method": {
          "type": "string",
          "enum": [
            "DIGITAL_SIGNATURE",
            "STRONG_CUSTOMER_AUTH",
            "API_DELEGATION",
            "MANDATE",
            "MULTISIG",
            "OTHER"
          ]
        },
        "authorized_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        },
        "authorization_scope": {
          "type": "string",
          "enum": [
            "SINGLE_PAYMENT",
            "PAYMENT_LIMIT",
            "PAYEE_LIMIT",
            "RECURRING_MANDATE"
          ]
        },
        "instruction_digest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "evidence_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "submitted_at",
        "external_reference",
        "network",
        "acceptance_status",
        "evidence_id"
      ],
      "properties": {
        "submitted_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        },
        "external_reference": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "network": {
          "type": "string",
          "minLength": 1
        },
        "acceptance_status": {
          "type": "string",
          "enum": [
            "ACCEPTED",
            "REJECTED",
            "PENDING"
          ]
        },
        "evidence_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "status_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status_event_id",
        "status",
        "occurred_at",
        "actor_id",
        "reason_code",
        "evidence_id"
      ],
      "properties": {
        "status_event_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "INITIATED",
            "AUTHORIZED",
            "SUBMITTED",
            "PENDING_EXTERNAL_CONFIRMATION",
            "EXECUTING",
            "SETTLED",
            "FAILED",
            "REVERSED",
            "REFUNDED_PARTIAL",
            "REFUNDED_FULL",
            "CHARGEBACK"
          ]
        },
        "occurred_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        },
        "actor_id": {
          "type": "string",
          "minLength": 1
        },
        "reason_code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "evidence_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "settlement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "settlement_status",
        "settled_at",
        "settled_amount",
        "currency",
        "external_reference",
        "source",
        "evidence_id"
      ],
      "properties": {
        "settlement_status": {
          "type": "string",
          "enum": [
            "SETTLED",
            "NOT_SETTLED"
          ]
        },
        "settled_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        },
        "settled_amount": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?$"
        },
        "currency": {
          "type": "string",
          "minLength": 1
        },
        "external_reference": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "enum": [
            "BANK",
            "CARD_NETWORK",
            "PAYMENT_NETWORK",
            "BLOCKCHAIN",
            "INTERNAL_LEDGER",
            "OTHER"
          ]
        },
        "evidence_id": {
          "type": "string",
          "minLength": 1
        },
        "alternative_basis_declared": {
          "type": "boolean",
          "description": "Section 10.2: settled amount uses a basis other than net_amount."
        },
        "reconciling_items": {
          "type": "string",
          "description": "Section 10.2: required where alternative_basis_declared is true."
        }
      }
    },
    "finality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finality_type",
        "rule_name",
        "rule_version",
        "reached_at",
        "evidence_id",
        "finality_state"
      ],
      "properties": {
        "finality_type": {
          "type": "string",
          "enum": [
            "OPERATIONAL",
            "LEGAL"
          ]
        },
        "rule_name": {
          "type": "string",
          "minLength": 1
        },
        "rule_version": {
          "type": "string",
          "minLength": 1
        },
        "reached_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        },
        "confirmations_required": {
          "type": "integer",
          "minimum": 0
        },
        "confirmations_observed": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_id": {
          "type": "string",
          "minLength": 1
        },
        "finality_state": {
          "type": "string",
          "enum": [
            "PENDING",
            "CONDITIONAL",
            "REVERSIBLE",
            "IRREVOCABLE"
          ],
          "description": "Finality state at the verification time (Section 10.6)."
        },
        "operational_finality_reached": {
          "type": "boolean",
          "description": "Section 10.6 condition 1."
        },
        "reversal_windows_expired": {
          "type": "boolean",
          "description": "Section 10.6 condition 2: refund, dispute and chargeback windows expired."
        },
        "window_expiry_evidence_id": {
          "type": "string",
          "minLength": 1,
          "description": "Section 10.6 condition 2: evidence of window expiry."
        },
        "obligated_party_can_reverse": {
          "type": "boolean",
          "description": "Section 10.6 condition 3."
        }
      }
    },
    "fee": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fee_id",
        "fee_type",
        "amount",
        "currency",
        "borne_by",
        "recipient_id"
      ],
      "properties": {
        "fee_id": {
          "type": "string",
          "minLength": 1
        },
        "fee_type": {
          "type": "string",
          "enum": [
            "NETWORK",
            "PROCESSING",
            "FX",
            "SERVICE",
            "OTHER"
          ]
        },
        "amount": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?$"
        },
        "currency": {
          "type": "string",
          "minLength": 1
        },
        "borne_by": {
          "type": "string",
          "enum": [
            "PAYER",
            "PAYEE",
            "THIRD_PARTY"
          ]
        },
        "recipient_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "exchange_rate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_currency",
        "target_currency",
        "rate",
        "source",
        "observed_at",
        "rounding_mode"
      ],
      "properties": {
        "source_currency": {
          "type": "string",
          "minLength": 1
        },
        "target_currency": {
          "type": "string",
          "minLength": 1
        },
        "rate": {
          "type": "string",
          "pattern": "^[0-9]*[1-9][0-9]*(\\.[0-9]+)?$|^[0-9]+\\.[0-9]*[1-9][0-9]*$"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "observed_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        },
