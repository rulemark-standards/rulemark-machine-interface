{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rulemark.org/schema/rm-s-exch-001-verification-record.schema.json",
  "title": "RM-S-EXCH-001 Exchange Transparency Verification Record",
  "type": "object",
  "required": [
    "record_id", "schema_version", "verification_point", "result_expires_at",
    "digest_algorithm", "standard", "conformity_subject", "operating_entity",
    "in_scope_entities", "assets", "reserve_addresses", "liability_commitment",
    "segregation", "withdrawals", "privileged_operations", "evidence",
    "requirement_results", "overall_result", "verifier", "signature"
  ],
  "properties": {
    "record_id": { "type": "string", "minLength": 1 },
    "schema_version": { "const": "1.0" },
    "verification_point": { "$ref": "#/$defs/utcTime" },
    "result_expires_at": { "$ref": "#/$defs/utcTime" },
    "digest_algorithm": { "const": "sha-256" },
    "standard": {
      "type": "object",
      "required": ["standard_id", "standard_version"],
      "properties": {
        "standard_id": { "const": "RM-S-EXCH-001" },
        "standard_version": { "const": "v1.0-F" }
      },
      "additionalProperties": true
    },
    "conformity_subject": {
      "type": "object",
      "required": ["platform_name", "canonical_domain", "licence_number", "reserve_address_set_sha256"],
      "properties": {
        "platform_name": { "type": "string", "minLength": 1 },
        "canonical_domain": { "type": "string", "minLength": 1 },
        "licence_number": { "type": ["string", "null"] },
        "reserve_address_set_sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": true
    },
    "operating_entity": {
      "type": "object",
      "required": ["legal_name", "jurisdiction", "registration_number"],
      "properties": {
        "legal_name": { "type": "string", "minLength": 1 },
        "jurisdiction": { "type": "string", "minLength": 1 },
        "registration_number": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "in_scope_entities": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {
        "type": "object", "required": ["entity_id"],
        "properties": { "entity_id": { "type": "string", "minLength": 1 } },
        "additionalProperties": true
      }
    },
    "assets": {
      "type": "array", "minItems": 1,
      "items": { "$ref": "#/$defs/asset" }
    },
    "reserve_addresses": {
      "type": "array", "minItems": 1,
      "items": { "$ref": "#/$defs/reserveAddress" }
    },
    "liability_commitment": {
      "type": "object",
      "required": ["commitment_root", "total_derivable", "inclusion_proof_available", "verification_method_uri", "total_reducible", "negatives_netted"],
      "properties": {
        "commitment_root": { "type": "string", "minLength": 1 },
        "total_derivable": { "const": true },
        "inclusion_proof_available": { "const": true },
        "verification_method_uri": { "type": "string", "minLength": 1 },
        "total_reducible": { "const": false },
        "negatives_netted": { "const": false }
      },
      "additionalProperties": true
    },
    "segregation": { "type": "object" },
    "withdrawals": { "type": "object" },
    "privileged_operations": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "related_party_exposure": { "type": "array", "items": { "type": "object" } },
    "material_events": { "type": "array", "items": { "type": "object" } },
    "evidence": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["evidence_id", "provider_id", "generated_at", "acquired_at", "uri", "sha256"],
        "properties": {
          "evidence_id": { "type": "string", "pattern": "^EVD-[0-9]{3}$" },
          "provider_id": { "type": "string", "minLength": 1 },
          "generated_at": { "$ref": "#/$defs/utcTime" },
          "acquired_at": { "$ref": "#/$defs/utcTime" },
          "uri": { "type": "string", "minLength": 1 },
          "sha256": { "$ref": "#/$defs/sha256" }
        },
        "additionalProperties": true
      }
    },
    "requirement_results": { "type": "array", "items": { "type": "object" } },
    "human_disclosure": { "type": "object" },
    "overall_result": {
      "type": "object", "required": ["result", "failure_codes"],
      "properties": {
        "result": { "enum": ["PASS", "CONDITIONAL", "DEFICIENT", "FAIL", "NOT_ASSESSED"] },
        "failure_codes": { "type": "array", "items": { "type": "string", "pattern": "^RMSEXCH-[A-Z]+-[0-9]{3}$" } }
      },
      "additionalProperties": true
    },
    "verifier": { "type": "object", "minProperties": 1 },
    "signature": {
      "type": "object", "minProperties": 1,
      "required": ["algorithm", "key_id", "signed_at", "value"],
      "properties": {
        "algorithm": { "type": "string", "minLength": 1 },
        "key_id": { "type": "string", "minLength": 1 },
        "signed_at": { "$ref": "#/$defs/utcTime" },
        "value": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "utcTime": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "decimalString": { "type": "string", "pattern": "^(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$" },
    "asset": {
      "type": "object",
      "required": ["asset", "network", "reserve_balance", "customer_liability", "unit", "decimals", "coverage_ratio", "max_withdrawal_processing_time"],
      "properties": {
        "asset": { "type": "string", "minLength": 1 },
        "network": { "type": "string", "minLength": 1 },
        "reserve_balance": { "$ref": "#/$defs/decimalString" },
        "customer_liability": { "$ref": "#/$defs/decimalString" },
        "unit": { "type": "string", "minLength": 1 },
        "decimals": { "type": "integer", "minimum": 0 },
        "coverage_ratio": { "$ref": "#/$defs/decimalString" },
        "max_withdrawal_processing_time": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "reserveAddress": {
      "type": "object",
      "required": ["network", "address", "holding_entity_id", "asset", "balance", "control_proof_method", "control_proof_reference", "control_proof_time"],
      "properties": {
        "network": { "type": "string", "minLength": 1 },
        "address": { "type": "string", "minLength": 1 },
        "holding_entity_id": { "type": "string", "minLength": 1 },
        "asset": { "type": "string", "minLength": 1 },
        "balance": { "$ref": "#/$defs/decimalString" },
        "control_proof_method": { "enum": ["SIGNATURE", "SPEND"] },
        "control_proof_reference": { "type": "string", "minLength": 1 },
        "control_proof_time": { "$ref": "#/$defs/utcTime" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
