{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rulemark.org/schema/rm-s-ai-del-001-verification-record.schema.json",
  "title": "RM-S-AI-DEL-001 Delegated Authority Verification Record",
  "type": "object",
  "required": ["record_id", "schema_version", "verification_point", "assessment_window_start", "result_expires_at", "digest_algorithm", "standard", "conformity_subject", "delegator", "operator", "agent", "authorization", "authority_scope", "delegation_chain", "revocation", "action_log", "actions", "evidence", "requirement_results", "overall_result", "verifier", "signature"],
  "properties": {
    "record_id": {"type":"string","minLength":1},
    "schema_version": {"const":"1.0"},
    "verification_point": {"$ref":"#/$defs/utcTime"},
    "assessment_window_start": {"$ref":"#/$defs/utcTime"},
    "result_expires_at": {"$ref":"#/$defs/utcTime"},
    "digest_algorithm": {"const":"sha-256"},
    "standard": {"type":"object","required":["standard_id","standard_version"],"properties":{"standard_id":{"const":"RM-S-AI-DEL-001"},"standard_version":{"const":"v1.0-F"}},"additionalProperties":true},
    "conformity_subject": {"type":"object","required":["delegator_id","operator_id","delegator_is_operator","agent_instance_id","agent_config_sha256","authorization_id"],"properties":{"delegator_id":{"type":"string","minLength":1},"operator_id":{"type":"string","minLength":1},"delegator_is_operator":{"type":"boolean"},"agent_instance_id":{"type":"string","minLength":1},"agent_config_sha256":{"$ref":"#/$defs/sha256"},"authorization_id":{"type":"string","minLength":1}},"additionalProperties":true},
    "delegator": {"type":"object","minProperties":1},
    "operator": {"type":"object","minProperties":1},
    "agent": {"type":"object","minProperties":1},
    "authorization": {"$ref":"#/$defs/authorization"},
    "authority_scope": {"type":"array","minItems":1,"items":{"$ref":"#/$defs/scope"}},
    "delegation_chain": {"type":"array","items":{"type":"object"}},
    "revocation": {"type":"object"},
    "action_log": {"type":"object","minProperties":1},
    "actions": {"type":"array","items":{"type":"object"}},
    "human_checkpoints": {"type":"array","items":{"type":"object"}},
    "material_events": {"type":"array","items":{"type":"object"}},
    "evidence": {"type":"array","minItems":1,"items":{"type":"object","required":["evidence_id","provider_id","generated_at","acquired_at","uri","sha256"],"properties":{"evidence_id":{"type":"string","pattern":"^EVD-[0-9]{3}$"},"provider_id":{"type":"string","minLength":1},"generated_at":{"$ref":"#/$defs/utcTime"},"acquired_at":{"$ref":"#/$defs/utcTime"},"uri":{"type":"string","minLength":1},"sha256":{"$ref":"#/$defs/sha256"}},"additionalProperties":true}},
    "requirement_results": {"type":"array","items":{"type":"object"}},
    "human_disclosure": {"type":"object"},
    "overall_result": {"type":"object","required":["result","failure_codes"],"properties":{"result":{"enum":["PASS","CONDITIONAL","DEFICIENT","FAIL","NOT_ASSESSED"]},"failure_codes":{"type":"array","items":{"type":"string","pattern":"^RMSAIDEL-[A-Z0-9]+-[0-9]{3}$"}}},"additionalProperties":true},
    "verifier": {"type":"object","minProperties":1},
    "signature": {"type":"object","required":["algorithm","key_id","signed_at","value"],"properties":{"algorithm":{"type":"string","minLength":1},"key_id":{"type":"string","minLength":1},"signed_at":{"$ref":"#/$defs/utcTime"},"value":{"type":"string","minLength":1}},"additionalProperties":true}
  },
  "$defs": {
    "utcTime":{"type":"string","pattern":"^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"},
    "sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},
    "decimalString":{"type":"string","pattern":"^(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$"},
    "authorization":{"type":"object","required":["authorization_id","delegator_id","agent_instance_id","agent_config_sha256","issuance_time","effective_time","expiry_time","signature"],"properties":{"authorization_id":{"type":"string","minLength":1},"delegator_id":{"type":"string","minLength":1},"agent_instance_id":{"type":"string","minLength":1},"agent_config_sha256":{"$ref":"#/$defs/sha256"},"issuance_time":{"$ref":"#/$defs/utcTime"},"effective_time":{"$ref":"#/$defs/utcTime"},"expiry_time":{"$ref":"#/$defs/utcTime"},"signature":{"type":"object","minProperties":1}},"additionalProperties":true},
    "scope":{"type":"object","required":["action_type","counterparties","human_checkpoint"],"properties":{"action_type":{"type":"string","minLength":1},"counterparties":{"type":"object","required":["mode"],"properties":{"mode":{"enum":["ENUMERATED","RULE","UNRESTRICTED"]},"values":{"type":"array","items":{"type":"string"}}},"additionalProperties":true},"human_checkpoint":{"type":"object","required":["required"],"properties":{"required":{"type":"boolean"}},"additionalProperties":true},"quantity":{"type":"object","properties":{"unit":{"type":"string","minLength":1},"decimals":{"type":"integer","minimum":0},"per_action_max":{"$ref":"#/$defs/decimalString"},"cumulative_max":{"$ref":"#/$defs/decimalString"},"cumulative_period_hours":{"type":"number","exclusiveMinimum":0}},"additionalProperties":true}},"additionalProperties":true}
  },
  "additionalProperties": true
}
